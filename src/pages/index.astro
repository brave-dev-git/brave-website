---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import { site } from "../config/site";
import { getCollection } from "astro:content";

const title =
  "Brave Security – cybersäkerhet, riskhantering och säkra AI-lösningar";
const description =
  "Brave Security hjälper ledning och IT att förstå, prioritera och hantera risker – cybersäkerhet, informationssäkerhet och säkerhetskultur.";
  
const latestPosts = (await getCollection("insikter"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---


<Layout title={title} description={description} lang="sv">
  <div id="top"></div>
  <Header variant="overlay" />

  <main class="container">
    <!-- HERO -->
    <section class="section hero">
      <div class="section-surface hero-surface">
        <img
          class="hero-bg"
          src="/starting-page.png"
          alt=""
          aria-hidden="true"
          decoding="async"
          loading="eager"
        />

        <div class="hero-inner">
          <div class="hero-media--wide" aria-hidden="true">
            <img
              src="/starting-page.png"
              alt=""
              loading="eager"
              decoding="async"
              width="1600"
              height="900"
            />
          </div>

          <div class="hero-grid">
            <div class="card hero-content">
              <h1 class="h1">No risk no reward.</h1>
              <p class="hero-sub">Säkerhet ska möjliggöra framgång, inte hindra den.</p>
              <p class="lead">
                Vi hjälper ledning och styrelser att förstå läget, prioritera rätt
                och fatta säkerhetsbeslut som håller.
              </p>
              <div class="cta-row">
                <a class="btn-primary" href="/#kontakt">Se var ni faktiskt står</a>
                <a class="btn-secondary" href="/#utmaningar">Se utmaningar</a>
              </div>
              <p class="micro">Snabbt första steg: maila eller ring – du når oss direkt.</p>
            </div>

            <a class="card link-card hero-side" href="/sakerhetspartnerskap/">
              <h2 class="h2">Er säkerhetspartner</h2>
              <ul class="hero-points">
                <li>
                  <span class="hero-point-icon" aria-hidden="true">→</span>
                  Faktabaserad riskbild — så att ni vet var ni faktiskt står.
                </li>
                <li>
                  <span class="hero-point-icon" aria-hidden="true">→</span>
                  Säkerhetsförmåga som håller — även när det verkligen gäller.
                </li>
                <li>
                  <span class="hero-point-icon" aria-hidden="true">→</span>
                  Mod att ta rätt beslut — med oss vid sidan om.
                </li>
              </ul>
            </a>
          </div>
        </div>
      </div>
    </section>


    <!-- UTMANINGAR -->
    <section id="utmaningar" class="section">
      <div class="section-surface">
        <div class="section-head">
          <h2 class="h2xl">Era utmaningar</h2>
          <p class="muted">
            Säkerhet börjar sällan med en produkt – den börjar med en fråga. Här är några vi ofta får.
          </p>
        </div>

      <div class="grid2">
        <a class="card link-card" href="/utmaningar/#upptackt-lagesbild">
          <h3 class="h3">Upptäckt & lägesbild</h3>
          <ul class="bullets">
            <li>Kommer vi märka om någon tar sig in i våra system?</li>
            <li>Har vi en realistisk bild av våra mest kritiska tillgångar och risker?</li>
          </ul>
        </a>

        <a class="card link-card" href="/utmaningar/#styrning-matning-mognad">
          <h3 class="h3">Styrning, mätning & mognad</h3>
          <ul class="bullets">
            <li>Hur mäter vi säkerhet och vet att vi blir bättre över tid?</li>
            <li>Hur kan vi jämföra vår säkerhetsnivå med andra i vår bransch?</li>
          </ul>
        </a>
      </div>

      <div class="cta-row">
        <a class="btn-secondary" href="/utmaningar/">Alla utmaningar</a>
        <a class="btn-primary" href="/#kontakt">Prata om er situation</a>
      </div>
      </div>
    </section>

    <!-- TJÄNSTER -->
    <section id="tjanster" class="section">
      <div class="section-surface">
        <div class="section-head">
          <h2 class="h2xl">Tjänster</h2>
          <p class="muted">
            Tre områden där vi oftast skapar effekt snabbt – och där AI-frågan ofta hänger ihop med helheten.
          </p>
        </div>

      <div class="grid3">
        <a class="card link-card" href="/tjanster/riskhantering/">
          <h3 class="h3">Riskhantering</h3>
          <p class="p">
            Struktur för att identifiera, värdera och prioritera risker – med tydliga åtgärder och ansvar.
          </p>
          <span class="link">Prata risk →</span>
        </a>

        <a class="card link-card" href="/tjanster/cybersakerhet/">
          <h3 class="h3">Cybersäkerhet & informationssäkerhet</h3>
          <p class="p">
            Från nuläge och gap till säkerhetsarkitektur, kontroll och genomförande – anpassat till din verklighet.
          </p>
          <span class="link">Stäm av läget →</span>
        </a>

        <a class="card link-card" href="/tjanster/sakerhetskultur-och-ovning/">
          <h3 class="h3">Säkerhetskultur & övning</h3>
          <p class="p">
            Beteenden, förmåga och beredskap: övningar som tränar beslut, roller och kommunikation när det gäller.
          </p>
          <span class="link">Planera övning →</span>
        </a>
      </div>
      </div>
    </section>

    <!-- MOGNADSANALYS CALLOUT -->
    <section class="section" aria-label="Säkerhetsmognadsanalys">
      <div class="section-surface promo-surface">
        <div class="promo-grid">
          <div class="promo-body">
            <p class="promo-eyebrow">Utgångspunkten för allt säkerhetsarbete</p>
            <h2 class="h2xl">Vet ni var ni faktiskt står?</h2>
            <p class="p">På 2–4 veckor får ni ett konkret beslutsunderlag — vad ni har, vad ni saknar och vad ni bör prioritera nu.</p>
            <ul class="bullets">
              <li>Objektiv bild av er säkerhetsmognad</li>
              <li>Tydlig prioritering av åtgärder</li>
              <li>Anpassat för ledning och styrelse</li>
            </ul>
            <div class="cta-row" style="margin-top: 1.2rem;">
              <a class="btn-accent" href="/tjanster/mognadsanalys/">Få klarhet i var ni faktiskt står →</a>
            </div>
            <p class="micro">Inga förberedelser krävs.</p>
          </div>
          <div class="promo-side">
            <a class="promo-badge" href="/tjanster/mognadsanalys/">Säkerhetsmognadsanalys</a>
          </div>
        </div>
      </div>
    </section>

    <!-- NIS2 -->
    <section class="section" aria-label="NIS2">
      <div class="section-surface">
        <header class="section-head">
          <h2 class="h2xl">NIS2 och cybersäkerhetslagen</h2>
        </header>
        <p class="p">
          Cybersäkerhetslagen (NIS2) ställer krav på riskhantering, incidentrapportering och
          ledningsansvar — med personligt ansvar för styrelse och ledning.
          Berörs ni direkt eller via er leverantörskedja?
        </p>
        <div class="cta-row" style="margin-top: 1rem;">
          <a class="btn-primary" href="/nis2/">Förstå vad NIS2 innebär</a>
          <a class="btn-secondary" href="/kontakt/">Se om ni berörs — och vad som krävs</a>
        </div>
      </div>
    </section>

    <!-- INSIKTER -->
    <section id="insikter" class="section" aria-label="Insikter">
      <div class="section-surface">
        <header class="section-head">
          <h2 class="h2xl">Insikter</h2>
          <p class="muted">Korta perspektiv och konkreta lärdomar inom cybersäkerhet, risk och AI.</p>
        </header>

        <div class="grid3">
          {latestPosts.map((post) => (
            <a class="card insights-post" href={`/insikter/${post.slug}/`}>
              <div class="insights-meta">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString("sv-SE")}
                </time>

                {post.data.tags?.length ? <span class="insights-dot">•</span> : null}
                {post.data.tags?.slice(0, 2).map((t) => (
                  <span class="insights-tag">{t}</span>
                ))}
              </div>

              <h3 class="h2" style="margin-top: 0.6rem;">{post.data.title}</h3>
              <p class="p" style="margin-top: 0.5rem;">{post.data.description}</p>
              <div class="insights-more">Läs →</div>
            </a>
          ))}
        </div>

        <div class="cta-row" style="margin-top: 1rem;">
          <a class="btn-secondary" href="/insikter/">Läs alla insikter</a>
        </div>
      </div>
    </section>

    <!-- AI -->
    <section id="ai" class="section" aria-label="AI och säkerhet">
     <div class="section-surface">
      <header class="section-head">
      <h2 class="section-title">AI &amp; säkerhet</h2>
      <p class="section-desc">
        AI införs ofta snabbare än styrning och kontroll. Vi hjälper er få effekt snabbt — utan att tappa kontroll på data,
        integritet, beslut och ansvar.
      </p>
    </header>

    <div class="grid2">
      <a class="card link-card" href="/ai-sakerhet/">
        <h3 class="card-title">Vanliga risker</h3>
        <ul class="bullets">
          <li>Dataexponering via prompts, loggar och integrationer.</li>
          <li>Otydligt ägarskap och ansvar mellan IT, verksamhet och leverantör.</li>
          <li>Otillräcklig spårbarhet: vad användes, av vem och när?</li>
        </ul>
        <span class="link" style="margin-top: 0.6rem; display: inline-block;">Läs mer →</span>
      </a>

      <a class="card link-card" href="/#kontakt">
        <h3 class="card-title">Snabbstart (2–4 veckor)</h3>
        <ul class="bullets">
          <li>Kartlägg use cases, dataflöden, integrationer och roller.</li>
          <li>Prioritera topprisker och åtgärder som ger faktisk riskreduktion.</li>
          <li>Sätt minimikrav (guardrails) för data, åtkomst och leverantör.</li>
        </ul>
        <span class="link" style="margin-top: 0.6rem; display: inline-block;">Se vad en snabbstart ger er →</span>
      </a>
    </div>
    </div>
  </section>

  <!-- OM OSS -->
  <section id="om-oss" class="section" aria-label="Om Brave Security">
    <div class="section-surface">
    <header class="section-head">
      <h2 class="section-title">Om oss</h2>
      <p class="section-desc">
        Brave Security hjälper styrelse, ledning och IT att förstå läget, prioritera rätt och genomföra åtgärder som faktiskt minskar risk.
        Tydligt, strukturerat och med fokus på beslut och genomförande.
      </p>
    </header>

    <div class="grid2">
      <a class="card link-card" href="/om-oss/">
        <h3 class="card-title">Så jobbar vi</h3>
        <ul class="bullets">
          <li>Beslutsunderlag som går att använda direkt.</li>
          <li>Praktiska åtgärder som går att driva i vardagen.</li>
          <li>Tydlig prioritering: vad ger effekt nu vs senare.</li>
        </ul>
        <span class="link" style="margin-top: 0.6rem; display: inline-block;">Mer om oss →</span>
      </a>

      <a class="card link-card" href="/#kontakt">
        <h3 class="card-title">När vi ofta kommer in</h3>
        <ul class="bullets">
          <li>Otydlig lägesbild och svårt att prioritera.</li>
          <li>Stora initiativ men begränsat med resurser.</li>
          <li>AI införs snabbare än styrning och kontroll.</li>
        </ul>
        <span class="link" style="margin-top: 0.6rem; display: inline-block;">Se hur vi kan hjälpa er konkret →</span>
      </a>
    </div>
    </div>
  </section>


    <!-- KONTAKT -->
    <section id="kontakt" class="section">
      <div class="section-surface">
        <div class="section-head">
          <h2 class="h2xl">Kontakt</h2>
          <p class="muted">Välj det som passar. Du når oss direkt.</p>
        </div>

        <div class="grid3">
          <a class="card link-card" href={`mailto:${site.email}?subject=Kontakt%20-%20Brave%20Security`}>
            <div class="contact-k">E-post</div>
            <div class="contact-v">{site.email}</div>
            <div class="contact-hint">Maila oss →</div>
          </a>

          <a class="card link-card" href={`tel:${site.phoneTel}`}>
            <div class="contact-k">Telefon</div>
            <div class="contact-v">{site.phoneDisplay}</div>
            <div class="contact-hint">Ring →</div>
          </a>

          <a class="card link-card" href={site.linkedinCompany} target="_blank" rel="noopener noreferrer">
            <div class="contact-k">LinkedIn</div>
            <div class="contact-v">Brave Security</div>
            <div class="contact-hint">Följ oss →</div>
          </a>
        </div>

      </div>
    </section>

  </main>
</Layout>

<style>

.hero { padding: 0; }

.hero-surface {
  position: relative;
  overflow: hidden;
  padding: 2.2rem;
}

.hero-bg {
  position: absolute;
  inset: -140px -220px;
  width: calc(100% + 440px);
  height: calc(100% + 280px);
  object-fit: cover;
  opacity: 0.22;
  filter: saturate(1.05);
  pointer-events: none;
  z-index: 0;
}

.hero-surface::after {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(2, 6, 23, 0.72);
  z-index: 0;
}

.hero-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 1.4rem;
}

.hero-media--wide {
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid rgba(148, 163, 184, 0.18);
  background: rgba(2, 6, 23, 0.25);
  height: clamp(220px, 26vw, 360px);
}

.hero-media--wide img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: 50% 50%;
}

.hero-grid {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 1rem;
  align-items: stretch;
}

.hero-side {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.hero-side h2 {
  font-size: 1.2rem;
  font-weight: 700;
}

@media (max-width: 820px) {
  .hero-grid { grid-template-columns: 1fr; }
}

.hero-points {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 1.1rem;
}

.hero-points li {
  display: flex;
  gap: 0.75rem;
  align-items: baseline;
  font-size: 1rem;
  line-height: 1.5;
  color: var(--text);
  padding-bottom: 1.1rem;
  border-bottom: 1px solid rgba(148, 163, 184, 0.12);
}

.hero-points li:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.hero-point-icon {
  color: var(--accent);
  font-weight: 700;
  flex-shrink: 0;
}

@media (max-width: 820px) {
  .hero-grid {
    grid-template-columns: 1fr;
  }
}

.hero-sub {
  margin: 0.5rem 0 1rem;
  font-size: 1.15rem;
  color: var(--accent);
  font-weight: 600;
}

.hero + .section { border-top: 0; }


@media (max-width: 980px) {
  .hero-surface { padding: 1.6rem; }
}

.promo-surface {
  border-top: 2px solid var(--accent);
}

.promo-grid {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 2rem;
  align-items: start;
}

@media (max-width: 640px) {
  .promo-grid { grid-template-columns: 1fr; }
}

.promo-eyebrow {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--accent-purple);
  margin-bottom: 0.6rem;
}

.promo-side {
  padding-top: 0.2rem;
}

.promo-badge {
  display: inline-block;
  padding: 0.4rem 1rem;
  border: 1px solid var(--accent-purple);
  border-radius: 999px;
  font-size: 0.85rem;
  color: var(--accent-purple);
  text-decoration: none;
  white-space: nowrap;
  transition: background 0.15s;
}

.promo-badge:hover {
  background: rgba(109, 77, 255, 0.1);
}

.btn-accent {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.7rem 2.1rem;
  border-radius: 999px;
  border: 1px solid var(--accent);
  font-size: 0.9rem;
  font-weight: 600;
  text-decoration: none;
  color: #fff;
  background: var(--accent);
  transition: background 0.15s ease, transform 0.15s ease;
}

.btn-accent:hover {
  background: #d4613d;
  border-color: #d4613d;
  transform: translateY(-1px);
}

</style>
