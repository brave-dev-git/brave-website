---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("insikter");
  return posts
    .filter((p) => !p.data.draft)
    .map((p) => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const title = `${post.data.seoTitle ?? post.data.title} – Brave Security`;
const description = post.data.description;
const canonicalUrl = `https://www.bravesecurity.se/insikter/${post.slug}/`;
const publishedDate = post.data.date.toISOString();

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.description,
  datePublished: publishedDate,
  url: canonicalUrl,
  author: {
    "@type": "Person",
    name: post.data.author?.name ?? "Jonas Stewén",
    url: post.data.author?.linkedin ?? "https://www.linkedin.com/in/jonasstewen/",
  },
  publisher: {
    "@type": "Organization",
    name: "Brave Security AB",
    url: "https://www.bravesecurity.se",
    logo: {
      "@type": "ImageObject",
      url: "https://www.bravesecurity.se/logo-brave-security.png",
    },
  },
};

const tagToService: Record<string, { label: string; href: string; description: string }> = {
  "cybersäkerhetslagen": { label: "NIS2 och cybersäkerhetslagen", href: "/tjanster/cybersakerhetslagen/", description: "Förstå kraven och vad de innebär för er organisation och ledning." },
  "NIS2": { label: "NIS2 – vad gäller för er?", href: "/nis2/", description: "Förstå kraven och vad de innebär för er organisation och ledning." },
  "leverantörsrisker": { label: "NIS2 och cybersäkerhetslagen", href: "/tjanster/cybersakerhetslagen/", description: "Förstå kraven och vad de innebär för er organisation och ledning." },
  "AI": { label: "AI & säkerhet", href: "/ai-sakerhet/", description: "Hantera AI-risker utan att bromsa användningen — data, styrning och ansvar." },
  "styrning": { label: "CISO as a Service", href: "/tjanster/ciso-as-a-service/", description: "Senior säkerhetsledning på deltid — strategiskt stöd utan fast anställning." },
  "CISO": { label: "CISO as a Service", href: "/tjanster/ciso-as-a-service/", description: "Senior säkerhetsledning på deltid — strategiskt stöd utan fast anställning." },
  "ledarskap": { label: "CISO as a Service", href: "/tjanster/ciso-as-a-service/", description: "Senior säkerhetsledning på deltid — strategiskt stöd utan fast anställning." },
  "cybersäkerhet": { label: "Cybersäkerhet", href: "/tjanster/cybersakerhet/", description: "Från nuläge och gap till åtgärder som faktiskt minskar risk." },
  "Cybersecurity": { label: "Cybersäkerhet", href: "/tjanster/cybersakerhet/", description: "Från nuläge och gap till åtgärder som faktiskt minskar risk." },
  "riskhantering": { label: "Riskhantering", href: "/tjanster/riskhantering/", description: "Struktur för att identifiera, värdera och prioritera rätt risker." },
  "sårbarhet": { label: "Assume breach", href: "/tjanster/assume-breach/", description: "Testa om ni märker ett angrepp — och hur långt en angripare faktiskt kommer." },
  "assume breach": { label: "Assume breach", href: "/tjanster/assume-breach/", description: "Testa om ni märker ett angrepp — och hur långt en angripare faktiskt kommer." },
  "riskworkshop": { label: "Riskworkshop", href: "/tjanster/riskworkshop/", description: "Gemensam bild av risker och prioriteringar — klar för beslut." },
  "mognad": { label: "Säkerhetsmognadsanalys", href: "/tjanster/mognadsanalys/", description: "Konkret bild av var ni faktiskt står — och vad ni bör prioritera nu." },
  "säkerhetsmognad": { label: "Säkerhetsmognadsanalys", href: "/tjanster/mognadsanalys/", description: "Konkret bild av var ni faktiskt står — och vad ni bör prioritera nu." },
  "mognadsanalys": { label: "Säkerhetsmognadsanalys", href: "/tjanster/mognadsanalys/", description: "Konkret bild av var ni faktiskt står — och vad ni bör prioritera nu." },
  "NIST CSF": { label: "Säkerhetsmognadsanalys", href: "/tjanster/mognadsanalys/", description: "Konkret bild av var ni faktiskt står — och vad ni bör prioritera nu." },
};

const related = (post.data.tags ?? [])
  .map((t) => tagToService[t])
  .filter(Boolean)
  .filter((item, idx, arr) => arr.findIndex((x) => x.href === item.href) === idx);
---

<Layout
  title={title}
  description={description}
  lang="sv"
  ogType="article"
  canonicalUrl={canonicalUrl}
  jsonLd={articleSchema}
>
  <Header />

  <main class="container">
    <section class="section">
      <div class="section-surface">
        <div class="prose prose--article">
          <article class="article">
            <header class="head">
              <a class="back" href="/insikter/">
                <span aria-hidden="true">←</span> Till Insikter
              </a>

              <h1 class="h1">{post.data.title}</h1>
              <div class="byline">
              {post.data.author?.name ? (
                <>
                  <span>
                    Skriven av {post.data.author.name}{post.data.author.role ? ` – ${post.data.author.role}` : ""}
                  </span>
              
              {post.data.author?.linkedin ? (
                  <>
                    <span class="sep">·</span>
                    <a href={post.data.author.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
                  </>
                ) : null}
                </>
              ) : (
                <span>Skriven av Brave Security</span>
              )}
            </div>
              <div class="meta">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString("sv-SE")}
                </time>
                {post.data.tags?.length ? <span class="dot">•</span> : null}
                {post.data.tags?.map((t) => <a class="tag" href={`/insikter/tagg/${encodeURIComponent(t)}/`}>{t}</a>)}
                
              </div>

              <p class="lead">{post.data.description}</p>
            </header>
            <div class="content">
              <Content />
            </div>
            {related.length > 0 && (
              <div class="related">
                <div class="related__k">Gå från insikt till handling</div>
                <div class="related__cards">
                  {related.map((r) => (
                    <a class="related__card" href={r.href}>
                      <span class="related__card-label">{r.label} →</span>
                      <span class="related__card-desc">{r.description}</span>
                    </a>
                  ))}
                </div>
              </div>
            )}      
            <section class="card cta" aria-label="Kontakt CTA">
              <h2 class="h2">Vill du bolla detta i er kontext?</h2>
              <p class="p">Hör av dig så tar vi ett kort, förutsättningslöst samtal.</p>
              <div class="cta-row">
                <a class="btn-primary" href="/kontakt/">Kontakt</a>
                <a class="btn-secondary" href="/tjanster/">Se tjänster</a>
              </div>
            </section>
          </article>
        </div>


      </div>
    </section>
  </main>
</Layout>


<style>
    /* Artikel-layout i samma stil som resten */
    .article {
      margin-top: 1.2rem;
    }

    /* Rytm: gör texten lättare att läsa */
    .article :is(p, ul, ol, blockquote) {
      margin: 0.9rem 0;
    }

    .article :is(h2, h3) {
      margin: 1.6rem 0 0.6rem;
    }

    .article ul, .article ol {
      padding-left: 1.2rem;
    }

    .article blockquote {
      margin: 1.2rem 0;
      padding: 0.9rem 1rem;
      border-left: 3px solid rgba(124, 58, 237, 0.7);
      background: rgba(2, 6, 23, 0.22);
      border-radius: 0.9rem;
    }

    /* Bilder i artiklar */
    .article img {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 1rem;
      border: 1px solid rgba(148,163,184,0.22);
    }

    .prose--article {
        max-width: 90ch;     /* test: 86–100ch */
        margin: 0 auto;      /* centrera i ytan */
      }


  .head { margin-bottom: 1rem; }
  
  .meta { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; color: rgba(229,231,235,0.75); font-size: 0.85rem; }
  .dot { opacity: 0.6; }
  .tag {
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    border: 1px solid rgba(148,163,184,0.25);
    background: rgba(2,6,23,0.22);
  }

  /* enkel typografi för markdown */
  .content :global(h2) { margin-top: 1.4rem; }
  .content :global(p) { line-height: 1.8; color: rgba(229,231,235,0.9); }
  .content :global(a) { color: rgba(203,213,245,1); text-underline-offset: 4px; }
  .content :global(ul) { line-height: 1.8; }

  .cta { margin-top: 1.4rem; }

  .back{
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  padding: 0.35rem 0.65rem;
  border-radius: 999px;
  border: 1px solid rgba(148,163,184,0.25);
  background: rgba(2,6,23,0.22);
  color: rgba(229,231,235,0.9);
  text-decoration: none;
  font-weight: 650;
  font-size: 0.85rem;
}
.back:hover{
  border-color: rgba(231,111,81,0.55);
}

.related{
  margin-top: 1rem;
  padding-top: 0.75rem;
  border-top: 1px solid rgba(148,163,184,0.14);
}
.related__k{
  color: rgba(229,231,235,0.75);
  font-size: 0.85rem;
  font-weight: 700;
  margin-bottom: 0.6rem;
}
.related__cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 0.5rem;
}

.related__card {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  padding: 0.55rem 0.8rem;
  border-radius: 0.65rem;
  border: 1px solid rgba(148, 163, 184, 0.18);
  background: rgba(2, 6, 23, 0.2);
  text-decoration: none;
  color: inherit;
  transition: border-color 0.15s, background 0.15s;
}

.related__card:hover {
  border-color: rgba(231, 111, 81, 0.45);
  background: rgba(2, 6, 23, 0.35);
}

.related__card-label {
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--text);
}

.related__card-desc {
  font-size: 0.75rem;
  color: rgba(229, 231, 235, 0.45);
  line-height: 1.45;
}
.meta { margin-top: 0.6rem; }
.lead { margin-top: 0.8rem; }
.tag { font-weight: 600; }

.byline{
  margin-top: .5rem;
  color: rgba(229,231,235,0.75);
  font-size: .9rem;
}
.byline__title{ opacity: .9; }

</style>
