---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";

const title = "Om oss – Brave Security";
const description =
  "Brave Security hjälper ledning och IT fatta beslut i cybersäkerhet, risk och AI – med struktur, prioritering och praktiskt genomförande.";

const linkedinCompany = "https://www.linkedin.com/company/bravesecurity/";
const linkedinPerson = "https://www.linkedin.com/in/jonasstewen/";
---

<Layout title={title} description={description} lang="sv">
  <Header />

  <main class="container">

  <!-- Intro / hero -->
  <section class="section">
    <div class="section-surface">
      <div class="hero-media" aria-hidden="true">
        <img
          src="/starting-page.png"
          alt=""
          width="1600"
          height="900"
          loading="eager"
          decoding="async"
        />
      </div>

      <header class="section-head">
        <h1 class="h1">Om Brave Security</h1>
        <p class="lead">
          Brave Security är en svensk säkerhetspartner inom cybersäkerhet, riskhantering och säkerhetskultur.
          Vi hjälper ledning och styrelser att förstå läget, prioritera rätt och genomföra åtgärder som faktiskt minskar risk.
        </p>
      </header>

      <div class="cta-row">
        <a class="btn-primary" href="/kontakt/">Boka ett förutsättningslöst möte</a>
        <a class="btn-secondary" href="/tjanster/">Se tjänster</a>
      </div>
    </div>
  </section>

  <!-- Grundare -->
  <section class="section" aria-label="Grundare">
    <div class="section-surface">
      <header class="section-head">
        <h2 class="h2xl">Grundaren</h2>
        <p class="muted">Grundare och senior rådgivare — med erfarenhet från båda sidor av säkerhetsbordet.</p>
      </header>

      <div class="founder-card card">
        <img
          src="/jonas-stewen.jpg"
          alt="Jonas Stewén, grundare Brave Security"
          class="founder-photo"
          width="160"
          height="160"
          loading="lazy"
          decoding="async"
        />
        <div class="founder-body">
          <div class="founder-name">Jonas Stewén</div>
          <div class="founder-title">Grundare, Brave Security AB</div>
          <p class="p">
            MSc Computer Science och CISA-certifierad med över 25 års erfarenhet inom informations- och cybersäkerhet.
            Bakgrund som CTO, konsultchef och VD — och parallellt alltid aktiv som senior rådgivare i cybersäkerhet
            direkt mot kunder.
          </p>
          <p class="p">
            Erfarenhet som spänner från teknisk grund — pentest, IT-forensik och säkerhetsramverk — till
            säkerhetsledning och styrelsenivå i nordiska och internationella koncerner. En kombination som
            ger trovärdighet i tekniska diskussioner och förmågan att omsätta säkerhet till affärsbeslut.
          </p>
          <p class="p">
            En återkommande del av arbetet har varit att mäta och utvärdera bolags säkerhetsmognad — och sedan
            hjälpa dem att faktiskt lyckas, genom konkret planering och genomförande snarare än enbart analys.
          </p>
          <p class="p">
            Brave Security grundades ur övertygelsen att säkerhet ska möjliggöra framgång, inte hindra den.
            Att jobba med rätt risker — inte undvika alla — är vad som skiljer de som lyckas från de som inte gör det.
          </p>
          <div class="cta-row" style="margin-top: 0.9rem;">
            <a class="btn-secondary" href={linkedinPerson} target="_blank" rel="noopener noreferrer">LinkedIn</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Vårt varför och övertygelse -->
  <section class="section" aria-label="Varfor">
    <div class="section-surface">
      <header class="section-head">
        <h2 class="h2xl">Varför Brave Security</h2>
        <p class="muted">
          En övertygelse om att säkerhet ska möjliggöra – inte begränsa.
        </p>
      </header>

      <div class="grid2">
        <article class="card">
          <h3 class="h2">Bakgrunden</h3>
          <p class="p">
            Brave Security grundades ur en enkel men stark övertygelse:
            <strong>säkerhet ska möjliggöra framgång – inte begränsa den.</strong>
          </p>
          <p class="p">
            Alltför ofta upplevs säkerhet som krånglig, hindrande och reaktiv.
            Vi vill förändra det – med ett arbetssätt som är strategiskt, personligt och faktiskt går att genomföra.
          </p>
        </article>

        <article class="card">
          <h3 class="h2">No risk, no reward</h3>
          <p class="p">
            Att undvika alla risker är inte säkerhet – det är stillestånd.
            Framgång kräver mod att ta rätt risker, med ögonen öppna.
          </p>
          <p class="p">
            Effekt uppstår när processer, teknik och människor samverkar.
            Ledarskap och kultur är det som avgör om säkerhetsarbetet håller i längden.
          </p>
          <div class="cta-row" style="margin-top: 0.9rem;">
            <a class="btn-secondary" href="/sakerhetspartnerskap/">Brave Security som säkerhetspartner</a>
          </div>
        </article>
      </div>

      <blockquote class="founder-quote">
        "Att undvika alla risker är inte säkerhet — det är stillestånd. De organisationer jag jobbar med vågar ta rätt risker, med ögonen öppna."
        <cite>— Jonas Stewén</cite>
      </blockquote>
    </div>
  </section>

  <!-- Hur vi jobbar -->
  <section class="section" aria-label="Hur vi jobbar">
    <div class="section-surface">
      <header class="section-head">
        <h2 class="h2xl">Hur vi jobbar</h2>
        <p class="muted">
          Tydligt, strukturerat och med fokus på beslut och genomförande.
        </p>
      </header>

      <div class="grid2">
        <article class="card">
          <h3 class="h2">Så jobbar vi</h3>
          <ul class="bullets">
            <li>Vi skapar en gemensam lägesbild — inte en rapport som ingen läser.</li>
            <li>Beslutsunderlag anpassat för ledning och IT, inte bara för revisorn.</li>
            <li>Prioritering utifrån faktisk risk — inte efter vad som är enklast att åtgärda.</li>
            <li>Vi stannar kvar tills saker är genomförda, inte bara utredda.</li>
          </ul>
        </article>

        <article class="card">
          <h3 class="h2">När vi ofta kommer in</h3>
          <ul class="bullets">
            <li>Ledningen vet inte var de faktiskt står säkerhetsmässigt.</li>
            <li>Säkerhetsarbetet är igång men ger inte tillräcklig effekt.</li>
            <li>NIS2 eller nya krav skapar tryck men oklart vad som faktiskt krävs.</li>
            <li>AI och ny teknik införs snabbare än styrning och kontroll hinner med.</li>
          </ul>
          <div class="cta-row" style="margin-top: 0.9rem;">
            <a class="btn-secondary" href="/utmaningar/">Se utmaningar</a>
            <a class="btn-secondary" href="/ai-sakerhet/">AI & säkerhet</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Vad du kan förvänta dig -->
  <section class="section">
    <div class="section-surface">
      <header class="section-head">
        <h2 class="h2xl">Vad du kan förvänta dig</h2>
        <p class="muted">
          Enkelt uttryckt: tydlighet, prioritering och stöd att få saker gjorda.
        </p>
      </header>

      <div class="grid3">
        <div class="mini-card">
          <div class="k">Tydlighet</div>
          <div class="p">En gemensam bild av risker, beroenden och vad som är viktigast.</div>
        </div>
        <div class="mini-card">
          <div class="k">Prioritering</div>
          <div class="p">En plan som går att genomföra – med ägarskap och nästa steg.</div>
        </div>
        <div class="mini-card">
          <div class="k">Genomförande</div>
          <div class="p">Stöd i att få saker gjorda, inte bara skriva dokument.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="section-surface">
      <header class="section-head">
        <h2 class="h2xl">Redo att prata?</h2>
        <p class="muted">
          Boka ett förutsättningslöst möte — vi lyssnar först och föreslår sedan.
        </p>
      </header>

      <div class="cta-row">
        <a class="btn-primary" href="/kontakt/">Kontakta oss</a>
        <a class="btn-secondary" href={linkedinCompany} target="_blank" rel="noopener noreferrer">
          Brave Security på LinkedIn
        </a>
      </div>
    </div>
  </section>


</main>

<style>
  .founder-card {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  .founder-photo {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    flex-shrink: 0;
    border: 2px solid rgba(148, 163, 184, 0.2);
  }

  .founder-name {
    font-size: 1.2rem;
    font-weight: 700;
    color: rgba(229, 231, 235, 0.95);
  }

  .founder-title {
    font-size: 0.9rem;
    color: rgba(229, 231, 235, 0.6);
    margin-bottom: 0.8rem;
    margin-top: 0.2rem;
  }

  .founder-body .p + .p {
    margin-top: 0.75rem;
  }

  .founder-quote {
    margin: 1rem 0 0.5rem;
    padding: 0.9rem 1rem;
    border-left: 3px solid rgba(124, 58, 237, 0.7);
    background: rgba(2, 6, 23, 0.22);
    border-radius: 0.9rem;
    font-style: italic;
    color: rgba(229, 231, 235, 0.85);
    line-height: 1.6;
  }

  .founder-quote cite {
    display: block;
    margin-top: 0.5rem;
    font-style: normal;
    font-size: 0.85rem;
    color: rgba(229, 231, 235, 0.55);
  }

  @media (max-width: 600px) {
    .founder-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .founder-card .cta-row {
      justify-content: center;
    }
  }
</style>

</Layout>


