---
type Subservice = {
  label: string;
  href: string;
  description?: string;
  soon?: boolean;
};

const { title, intro, items } = Astro.props as {
  title?: string;
  intro?: string;
  items: Subservice[];
};

const visible = (items ?? []).filter((i) => !i.soon);
---

{visible.length > 0 && (
  <section aria-label={title ?? "Tjänster inom området"}>
    <header class="section-head">
      <h2 class="h2xl">{title ?? "Tjänster inom området"}</h2>
      {intro && <p class="muted">{intro}</p>}
    </header>

    <div class="grid2">
      {visible.map((s) => (
        <a class="card link-card" href={s.href}>
          <h3 class="h2">{s.label}</h3>
          {s.description && <p class="p">{s.description}</p>}
        </a>
      ))}
    </div>
  </section>
)}