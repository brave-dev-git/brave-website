---
type Subservice = {
  label: string;
  href: string;
  description?: string;
  soon?: boolean;
};

const { title, intro, items } = Astro.props as {
  title?: string;
  intro?: string;
  items: Subservice[];
};

const visible = (items ?? []).filter((i) => !i.soon);
---

{visible.length > 0 && (
  <section class="mt-2" aria-label={title ?? "Undertjänster"}>
    <div class="stack">
      <div class="section-head">
        <h2 class="h2">{title ?? "Undertjänster"}</h2>
        {intro && <p class="muted prose">{intro}</p>}
      </div>

      <div class="grid3">
        {visible.map((s) => (
          <a class="link-card mini-card" href={s.href}>
            <div class="k">{s.label}</div>
            {s.description ? (
              <p class="muted mt-1">{s.description}</p>
            ) : (
              <p class="muted mt-1">Läs mer</p>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>
)}