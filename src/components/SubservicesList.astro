---
type Subservice = {
  label: string;
  href: string;
  description?: string;
  soon?: boolean;
};

const { title, intro, items } = Astro.props as {
  title?: string;
  intro?: string;
  items: Subservice[];
};

const visible = (items ?? []).filter((i) => !i.soon);
---

{visible.length > 0 && (
  <section  aria-label={title ?? "Tjänster inom området"}>
   
      <header class="section-head">
        <h2 class="h2x1">{title ?? "Tjänster inom området"}</h2>
        {intro && <p class="muted prose">{intro}</p>}
      </header>

        <div class="cta-row">
            {visible.map((s) => (
            <a class="btn-secondary" href={s.href}>{s.label}</a>
        ))}
        </div>
    </div>
  </section>
)}